# PostgreSQL async (Supabase): postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://localhost/rebalancer

# Optional — enables AI advisor + ticker-tag suggestions. All AI features no-op when unset.
GEMINI_API_KEY=

# Fernet key used to encrypt saved snapshots. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SNAPSHOT_ENCRYPTION_KEY=

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:5173
